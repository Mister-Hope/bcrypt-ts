{
  "name": "bcrypt-ts",
  "version": "9.0.0",
  "description": "bcrypt written in typescript",
  "keywords": [
    "bcrypt",
    "bcryptjs"
  ],
  "bugs": {
    "url": "https://github.com/Mister-Hope/bcrypt-ts/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/Mister-Hope/bcrypt-ts.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "browser": "./dist/browser.js",
  "types": "./dist/node.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "browser": "./dist/browser.js",
      "node": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "bench": "vitest bench",
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown -w",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepare": "husky",
    "prepublish": "run clean && pnpm run build",
    "test": "vitest --coverage"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "2.0.1",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@mr-hope/tsconfig": "0.0.4",
    "@types/node": "20.19.41",
    "@vitest/coverage-istanbul": "4.1.7",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.5",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.9",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
